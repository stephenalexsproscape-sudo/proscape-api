# Proscape API Environment Configuration
# Copy this file to .env and fill in values. NEVER commit .env with real secrets.
# See GEMINI.md for workflows.

# === REQUIRED ===
JWT_SECRET=your-super-long-random-jwt-secret-here-at-least-32-chars
DATABASE_URL=postgresql://user:pass@localhost:5432/proscape_db

# === OPTIONAL / PRODUCTION ===
NODE_ENV=production
PORT=3000

# CORS: comma-separated list of allowed origins (in addition to localhost defaults)
CORS_ORIGIN=https://your-prod-domain.example,https://another.example

# SSL / HTTPS (for direct server TLS, often handled by reverse proxy/Tailscale)
SSL_KEY_PATH=/path/to/key.pem
SSL_CERT_PATH=/path/to/cert.pem

# Email (for password resets, job completion notifications, new client alerts)
# If not set, falls back to Ethereal (dev-only test emails, previews logged)
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-pass
EMAIL_HOST=smtp.office365.com
FRONTEND_URL=https://your-frontend.example  # Used in reset links and staff message emails

# Admin notifications (export jobs, new clients). Falls back to a placeholder if unset.
ADMIN_EMAIL=ops@yourcompany.example

# Backup script (backup-db.js) reads DATABASE_URL above. Override dir if needed.
BACKUP_DIR=/home/stephen/proscape-backups

# Google Gemini API key (required for voice command AI feature).
# Get a free key at https://aistudio.google.com/app/apikey
# Then put it here and restart the API server.
GEMINI_API_KEY=your-gemini-api-key-here

# Emergency reset script (emergency-reset.js) - do not set in normal .env
# RESET_USERNAME=admin
# RESET_PASSWORD=...

# For frontend native/Capacitor builds, you may inject window.PROSCAPE_API_URL at runtime
# instead of rebuilding.
